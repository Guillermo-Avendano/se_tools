# SE ContentEdge — Shared Environment Configuration

SE_CE_TOOLS_IMAGE=rocketsoftware2030/se-ce-tools:12.6.0
SE_AGENT_IMAGE=rocketsoftware2030/se-agent:1.0.0
SE_AGENT_NAME=se-agent


DOCKER_PROJECT_NAME=contentedge

# ─── ContentEdge ───
# Source repository
CE_SOURCE_REPO_URL=https://services-us-virginia-m-1.skytap.com:8530
CE_SOURCE_REPO_NAME=Mobius
CE_SOURCE_REPO_USER=admin
CE_SOURCE_REPO_PASS=admin
CE_SOURCE_REPO_SERVER_USER=ADMIN
CE_SOURCE_REPO_SERVER_PASS=
CE_SOURCE_CERT=/workspace/conf/cert_source/ca.crt

# Target repository
CE_TARGET_REPO_URL=https://services-us-virginia-m-1.skytap.com:10123
CE_TARGET_REPO_NAME=Mobius
CE_TARGET_REPO_USER=admin
CE_TARGET_REPO_PASS=admin
CE_TARGET_REPO_SERVER_USER=ADMIN
CE_TARGET_REPO_SERVER_PASS=
CE_TARGET_CERT=/workspace/conf/cert_target/ca.crt

# ─── Archiving Policy Generation ───
POLICY_SAMPLE_LINES=400

# --- MobiusRemoteCLI ---
# Command templates have built-in defaults. Uncomment ONLY if you need to override.
# Auth is handled via application.yaml (created at startup from CE_*_REPO_* vars).
# ADELETE_TEMPLATE=adelete -s {REPO_NAME} -u {SERVER_USER} -r {CONTENT_CLASS} -t -c -n -y vfd
# ACREATE_TEMPLATE=acreate -f {FILE_PATH} -s {REPO_NAME} -u {SERVER_USER} -r {CONTENT_CLASS} -c {POLICY_NAME} -v 2
# ACREATE_LIST_TEMPLATE=acreate -f {FILE_PATH} -s {REPO_NAME} -u {SERVER_USER} -v 2
# VDRDBXML_TEMPLATE=vdrdbxml -s {REPO_NAME} -u {SERVER_USER} -f {XML_INPUT_FILE_PATH} -out {XML_OUTPUT_FILE_PATH} -v 2

# ─── Data Volume ───
DATA_PATH=./data

# ─── SE CE Tools (Web UI) ───
WEB_PORT=3000
API_PORT=8500

# ─── Agent (AI) ───
AGENT_PORT=8000
ANYTHINGLLM_PORT=3001

# LLM Provider: "ollama" or "llama_cpp"
LLM_PROVIDER=llama_cpp
EMBEDDING_PROVIDER=llama_cpp

# Ollama configuration (when LLM_PROVIDER=ollama)

OLLAMA_BASE_URL=http://192.168.0.92:11434
OLLAMA_MODEL=qwen3-vl:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# llama.cpp configuration (when LLM_PROVIDER=llama_cpp)
LLAMA_CPP_API_KEY=
LLAMA_CPP_MODEL=qwen2.5-7b-instruct
LLAMA_CPP_BASE_URL=http://llama-cpp-chat:8080/v1
LLAMA_CPP_TEMPERATURE=0.1
LLAMA_CPP_EMBED_MODEL=nomic-embed-text-v1.5
LLAMA_CPP_EMBED_BASE_URL=http://llama-cpp-embed:8080/v1
LLAMA_CPP_EMBED_API_KEY=

# llama.cpp optional services (download + local servers)
LLAMA_CPP_CHAT_PORT=8080
LLAMA_CPP_EMBED_PORT=8081
LLAMA_CPP_N_CTX=4096
LLAMA_CPP_EMBED_N_CTX=2048
LLAMA_CPP_N_GPU_LAYERS=0
LLAMA_CPP_CHAT_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLAMA_CPP_EMBED_MODEL_FILE=nomic-embed-text-v1.5-Q8_0.gguf
LLAMA_CPP_CHAT_MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-7B-Instruct-GGUF/resolve/main/Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLAMA_CPP_EMBED_MODEL_URL=https://huggingface.co/bartowski/nomic-embed-text-v1.5-GGUF/resolve/main/nomic-embed-text-v1.5-Q8_0.gguf

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=schema_memory

# ─── General ───
LOG_LEVEL=DEBUG
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000
