# SE-Content-Agent — Author: Guillermo Avendano
# Source repository
CE_SOURCE_REPO_URL=https://your-mobius-server:9848
CE_SOURCE_REPO_NAME=Mobius
CE_SOURCE_REPO_USER=admin
CE_SOURCE_REPO_PASS=admin
CE_SOURCE_REPO_SERVER_USER=ADMIN
CE_SOURCE_REPO_SERVER_PASS=
CE_SOURCE_CERT=/workspace/conf/cert_source/ca.crt

# Target repository (optional, for migration/compare)
CE_TARGET_REPO_URL=
CE_TARGET_REPO_NAME=
CE_TARGET_REPO_USER=
CE_TARGET_REPO_PASS=
CE_TARGET_REPO_SERVER_USER=
CE_TARGET_REPO_SERVER_PASS=
CE_TARGET_CERT=/workspace/conf/cert_target/ca.crt

# ─── PostgreSQL ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agent_db

# ─── Qdrant ───
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=schema_memory

# ─── Ollama ───
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gpt-oss:latest
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama

# ─── LLM Provider: "ollama" or "llama_cpp" ───
LLM_PROVIDER=ollama

# ─── llama.cpp server (when LLM_PROVIDER=llama_cpp) ───
LLAMA_CPP_API_KEY=
LLAMA_CPP_MODEL=llama-3.1-8b-instruct
LLAMA_CPP_BASE_URL=http://host.docker.internal:8080/v1
LLAMA_CPP_TEMPERATURE=0.1
LLAMA_CPP_EMBED_MODEL=nomic-embed-text
LLAMA_CPP_EMBED_BASE_URL=
LLAMA_CPP_EMBED_API_KEY=

# ─── Browserless ───
BROWSERLESS_URL=http://browserless:3000

# ─── App ───
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000
MAX_QUERY_ROWS=1000
SQL_READONLY=true
